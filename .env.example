# Copy this file to `.env` and fill in your keys.
# `.env` is gitignored — real keys stay local and are never committed/pushed.

# Required for the LLM agents (run_react / run_cot / summarize / LLM judges)
OPENAI_API_KEY=sk-...

# Required for web search (Serper) and the find_paper_quotes pipeline
SERPER_API_KEY=...

# Optional: higher-rate-limit / faster Hugging Face model downloads
HF_TOKEN=
